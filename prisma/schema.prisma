datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ReviewStatusDb {
  queued
  approved
  rejected
}

enum PaymentStatusDb {
  pending
  paid
}

enum TransbankTransactionStatusDb {
  created
  paid
  rejected
}

enum TransbankRequestTypeDb {
  checkup
  chronic_control
}

enum OrderPdfCategoryDb {
  laboratory
  image
  procedure
  interconsultation
}

enum SymptomsRequestStatusDb {
  draft
  paid
  in_flow
  pending_validation
  validated
  rejected
}

model Healthcheck {
  id        String   @id @default(cuid())
  key       String   @unique
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                     String                 @id @default(cuid())
  name                   String
  email                  String                 @unique
  passwordHash           String
  passwordSalt           String
  profileFirstName       String
  profilePaternalSurname String                 @default("")
  profileMaternalSurname String                 @default("")
  profileRut             String                 @default("")
  profileBirthDate       String                 @default("")
  profileEmail           String
  profilePhone           String                 @default("")
  profileAddress         String                 @default("")
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  sessions               Session[]
  checkups               CheckupRequest[]
  chronicControls        ChronicControlRequest[]
  symptomsRequests       SymptomsRequest[]
}

model Session {
  token     String   @id
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model CheckupRequest {
  id                    String         @id
  userId                String?
  input                 Json
  patientFirstName      String
  patientPaternalSurname String        @default("")
  patientMaternalSurname String        @default("")
  patientRut            String         @default("")
  patientBirthDate      String         @default("")
  patientEmail          String         @default("")
  patientPhone          String         @default("")
  patientAddress        String         @default("")
  rec                   Json
  reviewStatus          ReviewStatusDb @default(queued)
  queuedAt              DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  orderId               String?
  orderEmailSentAt      DateTime?
  orderEmailMessageId   String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  user                  User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  payment               CheckupPayment?

  @@index([userId])
}

model ChronicControlRequest {
  id                    String                 @id
  userId                String?
  conditions            Json
  patientFirstName      String
  patientPaternalSurname String               @default("")
  patientMaternalSurname String               @default("")
  patientRut            String                 @default("")
  patientBirthDate      String                 @default("")
  patientEmail          String                 @default("")
  patientPhone          String                 @default("")
  patientAddress        String                 @default("")
  yearsSinceDiagnosis   Int
  hasRecentChanges      Boolean
  usesMedication        Boolean
  selectedMedications   Json
  rec                   Json
  reviewStatus          ReviewStatusDb         @default(queued)
  queuedAt              DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  orderId               String?
  orderEmailSentAt      DateTime?
  orderEmailMessageId   String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  payment               ChronicControlPayment?

  @@index([userId])
}

model SymptomsRequest {
  id                     String                  @id
  userId                 String?
  symptomsText           String
  flowId                 String                  @default("")
  oneLinerSummary        String                  @default("")
  primarySymptom         String                  @default("")
  secondarySymptoms      Json
  patientFirstName       String
  patientPaternalSurname String                  @default("")
  patientMaternalSurname String                  @default("")
  patientRut             String                  @default("")
  patientBirthDate       String                  @default("")
  patientSex             String                  @default("")
  patientEmail           String                  @default("")
  patientPhone           String                  @default("")
  patientAddress         String                  @default("")
  antecedents            Json
  interpretation         Json
  followUpQuestions      Json
  followUpAnswers        Json
  suggestedTests         Json
  selectedTests          Json
  notes                  Json
  engineVersion          String                  @default("")
  cachedInput            String                  @default("")
  reviewStatus           SymptomsRequestStatusDb @default(draft)
  validatedByEmail       String?
  validatedAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  user                   User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  payment                SymptomsPayment?
  transactions           SymptomsPaymentTransaction[]
  pdfAssets              SymptomsOrderPdfAsset[]

  @@index([userId])
  @@index([reviewStatus, createdAt])
  @@index([validatedByEmail, validatedAt])
}

model CheckupPayment {
  requestId   String          @id
  amount      Int
  currency    String
  paymentId   String          @unique
  cardLast4   String
  cardholder  String
  status      PaymentStatusDb @default(pending)
  createdAt   DateTime        @default(now())
  paidAt      DateTime?
  updatedAt   DateTime        @updatedAt
  request     CheckupRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model ChronicControlPayment {
  requestId   String               @id
  amount      Int
  currency    String
  paymentId   String               @unique
  cardLast4   String
  cardholder  String
  status      PaymentStatusDb      @default(pending)
  createdAt   DateTime             @default(now())
  paidAt      DateTime?
  updatedAt   DateTime             @updatedAt
  request     ChronicControlRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model SymptomsPayment {
  requestId   String          @id
  amount      Int
  currency    String
  paymentId   String          @unique
  cardLast4   String
  cardholder  String
  status      PaymentStatusDb @default(pending)
  createdAt   DateTime        @default(now())
  paidAt      DateTime?
  updatedAt   DateTime        @updatedAt
  request     SymptomsRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model TransbankPaymentTransaction {
  id                 String                       @id @default(cuid())
  orderId            String                       @unique
  sessionId          String
  requestType        TransbankRequestTypeDb
  requestId          String
  amount             Int
  token              String                       @unique
  webpayUrl          String
  status             TransbankTransactionStatusDb @default(created)
  authorizationCode  String?
  buyOrder           String?
  responseCode       Int?
  paymentTypeCode    String?
  cardLast4          String?
  transactionDate    DateTime?
  transbankResponse  Json?
  errorReason        String?
  committedAt        DateTime?
  paidAt             DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([requestType, requestId])
  @@index([status, createdAt])
}

model SymptomsPaymentTransaction {
  id                String                       @id @default(cuid())
  requestId         String
  orderId           String                       @unique
  sessionId         String
  amount            Int
  token             String                       @unique
  webpayUrl         String
  status            TransbankTransactionStatusDb @default(created)
  authorizationCode String?
  buyOrder          String?
  responseCode      Int?
  paymentTypeCode   String?
  cardLast4         String?
  transactionDate   DateTime?
  transbankResponse Json?
  errorReason       String?
  committedAt       DateTime?
  paidAt            DateTime?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  request           SymptomsRequest              @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([status, createdAt])
}

model OrderPdfAsset {
  id          String                 @id @default(cuid())
  requestType TransbankRequestTypeDb
  requestId   String
  category    OrderPdfCategoryDb
  fileName    String
  blobUrl     String
  blobPath    String
  sizeBytes   Int
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([requestType, requestId, category])
  @@index([requestType, requestId])
}

model SymptomsOrderPdfAsset {
  id        String          @id @default(cuid())
  requestId String
  category  OrderPdfCategoryDb
  fileName  String
  blobUrl   String
  blobPath  String
  sizeBytes Int
  signedAt  DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  request   SymptomsRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, category])
  @@index([requestId])
}
